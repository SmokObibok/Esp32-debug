{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ESP32S3 Debug Zephyr",
      "type": "cortex-debug",
      "request": "launch",

      "gdbPath": "C:/Users/barte/zephyr-sdk-0.17.4/xtensa-espressif_esp32s3_zephyr-elf/bin/xtensa-espressif_esp32s3_zephyr-elf-gdb.exe",
      "executable": "${workspaceFolder}/build/zephyr/zephyr.elf",
